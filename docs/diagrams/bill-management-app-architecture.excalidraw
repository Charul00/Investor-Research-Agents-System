      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Data minimization rule\nDo not persist full raw email long term.\nKeep only normalized bill fields and short-lived raw cache with TTL for retries or manual review.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 48,
      "containerId": null,
      "originalText": "Data minimization rule\nDo not persist full raw email long term.\nKeep only normalized bill fields and short-lived raw cache with TTL for retries or manual review.",
      "lineHeight": 1.25
    },
