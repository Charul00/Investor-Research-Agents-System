# Frontend (put in frontend/.env.local for local frontend development)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend (copy this file to backend/.env)
API_V1_PREFIX=/api/v1
PROJECT_NAME=Investment Research API
ENVIRONMENT=development
SECRET_KEY=replace-this-with-a-long-random-secret-at-least-32-chars
DATABASE_URL=postgresql+psycopg://research:research@localhost:5432/investment_research
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTO_CREATE_TABLES=false
SEED_DEMO_DATA=false

# Local Postgres bootstrap for docker-compose.yml
POSTGRES_DB=investment_research
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_PORT=5432

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Real-time market and fundamentals providers
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# SEC EDGAR requires a descriptive User-Agent, not a secret key.
# Format example: InvestmentResearchOS/1.0 your-email@example.com
SEC_USER_AGENT=

# Vector RAG provider
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=investment_research_documents

# Low-latency cache provider
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_ENABLED=true
MARKET_CACHE_TTL_SECONDS=120
NEWS_CACHE_TTL_SECONDS=900
DOCUMENT_CACHE_TTL_SECONDS=3600
